# eval price-data cache (derived, regenerated by fetch_history()/data_audit.py -- see eval/data/MANIFEST.json for the real source-of-truth checksums)
eval/.yf_cache/
# eval forecaster-prediction cache (derived; regenerated by eval_recommendation.py / tune_strategy.py walk-forward)
eval/.pred_cache/
# eval charts (derived; regenerated by `python eval/run_all.py`). Un-ignore if you want to commit paper figures.
eval/results/


# --- forward test (eval/forward) -------------------------------------------
# Derived price cache: re-fetched from Yahoo v8 on demand, ~2MB/day.
eval/forward/_pricecache/
# Scheduled-job stdout.
eval/forward/_logs/
# Smoke-test stores.
eval/forward/_smoke*/
# NOTE: eval/forward/_runs/ (sealed predictions + outcomes) and
# eval/forward/_memory/ (curated lessons) are deliberately NOT ignored --
# they are the forward test's primary research artifact and their whole
# value is being an auditable, tamper-evident record over time.
